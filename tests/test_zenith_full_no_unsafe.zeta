// ─────────────────────────────────────────────

extern fn rmdir(path: string) -> i64;
extern fn unlink(path: string) -> i64;

fn timestamp_us() -> i64 {
    // Returns a rough unique-ish number for temp paths
    extern fn clock_gettime(clk_id: i64, tp: i64) -> i64;
    0 // stub — caller will append
}

// ─────────────────────────────────────────────
// Basic CRUD (replaces/extends originals)
// ─────────────────────────────────────────────

fn test_open_close() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    db.is_open()
}

fn test_set_get() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(42, 100);
    tree.get(42) == 100
}

fn test_get_missing() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.get(999) == 0
}

fn test_update() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(42, 100);
    tree.insert(42, 200);
    tree.get(42) == 200
}

fn test_delete_existing() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(42, 100);
    let deleted = tree.delete(42);
    let val = tree.get(42);

    deleted && val == 0
}

// ─────────────────────────────────────────────
// Edge cases
// ─────────────────────────────────────────────

fn test_delete_nonexistent() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.delete(42) == false
}

fn test_key_zero() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(0, 999);
    tree.get(0) == 999
}

fn test_value_zero() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(77, 0);
    tree.get(77) == 0
}

fn test_negative_keys() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(-1, 100);
    tree.insert(-100, 200);
    tree.insert(-9999, 300);

    tree.get(-1) == 100 && tree.get(-100) == 200 && tree.get(-9999) == 300
}

fn test_delete_reinsert() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(42, 100);
    tree.delete(42);
    let v1 = tree.get(42);  // Should be 0

    tree.insert(42, 200);   // Re-insert
    let v2 = tree.get(42);  // Should be 200

    v1 == 0 && v2 == 200
}

fn test_large_values() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(1, 9223372036854775807);  // i64::MAX
    tree.insert(2, -9223372036854775808); // i64::MIN

    tree.get(1) == 9223372036854775807 && tree.get(2) == -9223372036854775808
}

// ─────────────────────────────────────────────
// Multiple keys (unsorted insert)
// ─────────────────────────────────────────────

fn test_multi_key() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(10, 1);
    tree.insert(20, 2);
    tree.insert(30, 3);
    tree.insert(5, 0);
    tree.insert(15, 4);
    tree.insert(25, 5);

    tree.get(10) == 1 && tree.get(20) == 2 && tree.get(30) == 3
    && tree.get(5) == 0 && tree.get(15) == 4 && tree.get(25) == 5
}

// ─────────────────────────────────────────────
// B+ tree node split (many keys)
// ─────────────────────────────────────────────

fn test_tree_split() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    let mut i: i64 = 0;
    while i < 1000 {
        tree.insert(i, i * 2);
        i += 1;
    }

    let mut ok: bool = true;
    let mut j: i64 = 0;
    while j < 1000 {
        if tree.get(j) != j * 2 {
            ok = false;
        }
        j += 1;
    }

    ok
}

fn test_large_batch() -> bool {
    // Same as tree_split but larger — exercises more split levels
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    let count: i64 = 10000;

    let mut i: i64 = 0;
    while i < count {
        tree.insert(i, count - i);  // Descending values
        i += 1;
    }

    let mut ok: bool = true;
    let mut j: i64 = 0;
    while j < count {
        if tree.get(j) != count - j {
            ok = false;
        }
        j += 1;
    }

    ok
}

fn test_reverse_insert() -> bool {
    // Insert in descending order — exercises left-side tree growth
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    let mut i: i64 = 999;
    while i >= 0 {
        tree.insert(i, i + 1000);
        i -= 1;
    }

    let mut ok: bool = true;
    let mut j: i64 = 0;
    while j < 1000 {
        if tree.get(j) != j + 1000 {
            ok = false;
        }
        j += 1;
    }

    ok
}

fn test_sparse_keys() -> bool {
    // Sparse keys far apart — tests the B+ tree node boundaries
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(1, 10);
    tree.insert(1000000, 20);
    tree.insert(2000000000, 30);

    tree.get(1) == 10 && tree.get(1000000) == 20 && tree.get(2000000000) == 30
}

// ─────────────────────────────────────────────
// Scan
// ─────────────────────────────────────────────


fn test_scan_all() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(1, 10);
    tree.insert(2, 20);
    tree.insert(3, 30);

    let keys_buf = alloc::alloc(32);
    let vals_buf = alloc::alloc(32);

    let count = tree.scan(0, keys_buf, vals_buf, 4);

    alloc::dealloc(keys_buf);
    alloc::dealloc(vals_buf);

    count == 3  // Should find all 3 keys starting from 0
}

fn test_scan_beyond_max() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(10, 100);

    let keys_buf = alloc::alloc(8);
    let vals_buf = alloc::alloc(8);

    let count = tree.scan(999, keys_buf, vals_buf, 1);

    alloc::dealloc(keys_buf);
    alloc::dealloc(vals_buf);

    count == 0  // No keys >= 999
}

// ─────────────────────────────────────────────
// Compaction
// ─────────────────────────────────────────────

fn test_compact_empty() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    let merged = tree.compact();
    merged == 0  // Nothing to compact in an empty tree
}

fn test_compact_underfull() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    // Insert a few keys, then delete most to create underfull leaves
    let mut i: i64 = 0;
    while i < 500 {
        tree.insert(i, i);
        i += 1;
    }

    // Delete most keys to make leaves underfull
    let mut j: i64 = 10;
    while j < 490 {
        tree.delete(j);
        j += 1;
    }

    // Compact should merge the sparse remaining data
    let merged = tree.compact();

    // Verify remaining keys are still correct
    let v0 = tree.get(0);
    let v9 = tree.get(9);
    let v490 = tree.get(490);
    let v499 = tree.get(499);

    v0 == 0 && v9 == 9 && v490 == 490 && v499 == 499
}

