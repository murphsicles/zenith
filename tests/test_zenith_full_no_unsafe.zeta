// ─────────────────────────────────────────────
// Hot cache
// ─────────────────────────────────────────────

fn test_hot_cache_repeated_get() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    tree.insert(42, 100);

    // Get the same key multiple times — exercises hot cache
    let r1 = tree.get(42);
    let r2 = tree.get(42);
    let r3 = tree.get(42);
    let r4 = tree.get(42);

    r1 == 100 && r2 == 100 && r3 == 100 && r4 == 100
}

fn test_hot_cache_negative() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);
    let tree = db.open_tree("default");

    // First miss populates negative cache
    let r1 = tree.get(999);
    let r2 = tree.get(999);
    let r3 = tree.get(999);

    r1 == 0 && r2 == 0 && r3 == 0
}

// ─────────────────────────────────────────────
// Flush
// ─────────────────────────────────────────────

fn test_flush_temporary() -> bool {
    let config = Config::new().temporary(true);
    let db = Db::open(config);

    db.set(1, 100);
    let flushed = db.flush();
    let val = db.get(1);

    flushed && val == 100
}

// ─────────────────────────────────────────────
// Config validation
// ─────────────────────────────────────────────

fn test_config_validation_valid() -> bool {
    let config = Config::new()
        .path("/tmp/zenith_test")
        .cache_size(64 * 1024 * 1024)
        .compression_level(3)
        .leaf_fanout(1024);

    let result = config.validate();
    // Result type — Ok is truthy
    if result {
        true
    } else {
        false
    }
}

fn test_config_empty_path_fails() -> bool {
    let config = Config::new()
        .path("")
        .temporary(false);  // Non-temporary with empty path

    let result = config.validate();
    // Should be Err (InvalidConfig)
    if result {
        false  // Valid when should be invalid
    } else {
        true   // Correctly invalid
    }
}

fn test_config_small_cache_fails() -> bool {
    let config = Config::new()
        .path("/tmp/zenith_test")
        .cache_size(512);  // Too small — minimum is 1MB

    let result = config.validate();
    if result {
        false
    } else {
        true
    }
}

fn test_config_small_fanout_fails() -> bool {
    let config = Config::new()
        .path("/tmp/zenith_test")
        .leaf_fanout(8);  // Below minimum of 16

    let result = config.validate();
    if result {
        false
    } else {
        true
    }
}

fn test_config_scan_percent_bounds() -> bool {
    let config = Config::new()
        .path("/tmp/zenith_test")
        .cache_scan_percent(150);  // Should be clamped to 100

    // Can't easily test the field value, but test it doesn't crash
    true
}

// ─────────────────────────────────────────────
// CTFE: Size classes (heap internals)
// ─────────────────────────────────────────────

fn test_size_class_constants() -> bool {
    // Verify compile-time constants are correct
    zenith::heap::MIN_ALLOC == 32
    && zenith::heap::MAX_ALLOC == 16 * 1024 * 1024
    && zenith::heap::NUM_CLASSES == 64
}

fn test_slot_size_for_class() -> bool {
    zenith::heap::slot_size_for_class(0) == 32
    && zenith::heap::slot_size_for_class(1) > 32
}

fn test_size_class_index() -> bool {
    let s0 = zenith::heap::size_class_index(32);    // Exact MIN_ALLOC
    let s1 = zenith::heap::size_class_index(33);    // Just above MIN_ALLOC
    let s2 = zenith::heap::size_class_index(64);
    let s3 = zenith::heap::size_class_index(1024);
    let s4 = zenith::heap::size_class_index(16 * 1024 * 1024);  // MAX_ALLOC
    let s5 = zenith::heap::size_class_index(17 * 1024 * 1024);  // Over MAX_ALLOC

    s0 == 0 && s1 >= 0 && s4 < 64 && s5 < 64
}

fn test_class_sizes_monotonic() -> bool {
    // Each subsequent class must have a larger slot size
    let prev = zenith::heap::slot_size_for_class(0);
    let s1 = zenith::heap::slot_size_for_class(1);
    let s2 = zenith::heap::slot_size_for_class(2);
    let s10 = zenith::heap::slot_size_for_class(10);
    let s30 = zenith::heap::slot_size_for_class(30);
    let s63 = zenith::heap::slot_size_for_class(63);

    prev == 32 && s1 > prev && s2 > s1
    && s10 > s2 && s30 > s10 && s63 > s30
}

fn test_tag_untag_roundtrip() -> bool {
    // Tagged offsets: offset + class_idx in bottom 6 bits
    let offset: i64 = 4096;
    let class: i64 = 5;

    let tagged = zenith::heap::tag_slot(offset, class);
    let recovered_offset = zenith::heap::untag_offset(tagged);
    let recovered_class = zenith::heap::untag_class(tagged);

    recovered_offset == offset && recovered_class == class
}

fn test_tag_untag_all_classes() -> bool {
    // Verify tag/untag works for all 64 size classes
    let mut ok: bool = true;
    let mut c: i64 = 0;
    while c < 64 {
        let tagged = zenith::heap::tag_slot(8192, c);
        let off = zenith::heap::untag_offset(tagged);
        let cls = zenith::heap::untag_class(tagged);
        if off != 8192 || cls != c {
            ok = false;
        }
        c += 1;
    }
    ok
}

// ─────────────────────────────────────────────
// Arena (node allocator)
// ─────────────────────────────────────────────

fn test_arena_alloc() -> bool {
    let mut arena = zenith::alloc::Arena::new();

    let n1 = arena.alloc_node();
    let n2 = arena.alloc_node();
    let n3 = arena.alloc_node();

    // Pointers should be distinct and page-aligned
    n1 != 0 && n2 != 0 && n3 != 0
    && n1 != n2 && n2 != n3
}

fn test_arena_reset() -> bool {
    let mut arena = zenith::alloc::Arena::new();

    let before = arena.allocated();

    let _n1 = arena.alloc_node();
    let _n2 = arena.alloc_node();

    arena.reset();
    let after = arena.allocated();

    after < before  // Should have freed memory
}

// ─────────────────────────────────────────────
// Metadata store (pub API via Db)
// ─────────────────────────────────────────────

// MetadataStore is self-contained but cannot be tested directly
// from outside the crate without pub re-export.
// It's exercised indirectly via persistent DB tests.

// ─────────────────────────────────────────────
// Main test runner
// ─────────────────────────────────────────────

fn main() -> i64 {
    let tests: [fn() -> bool; 39] = [
        // Basic CRUD
        test_open_close,
        test_set_get,
        test_get_missing,
        test_update,
        test_delete_existing,

        // Edge cases
        test_delete_nonexistent,
        test_key_zero,
        test_value_zero,
        test_negative_keys,
        test_delete_reinsert,
        test_large_values,

        // Multi-key
        test_multi_key,

        // Tree splits & large batches
        test_tree_split,
        test_large_batch,
        test_reverse_insert,
        test_sparse_keys,

        // Scan
        test_scan_all,
        test_scan_beyond_max,

        // Compaction
        test_compact_empty,
        test_compact_underfull,

        // Db convenience
        test_db_set_get,
        test_db_delete,

        // Multiple trees
        test_multiple_trees,

        // Hot cache
        test_hot_cache_repeated_get,
        test_hot_cache_negative,

        // Flush
        test_flush_temporary,

        // Config validation
        test_config_validation_valid,
        test_config_empty_path_fails,
        test_config_small_cache_fails,
        test_config_small_fanout_fails,
        test_config_scan_percent_bounds,

        // CTFE size classes
        test_size_class_constants,
        test_slot_size_for_class,
        test_size_class_index,
        test_class_sizes_monotonic,
        test_tag_untag_roundtrip,
        test_tag_untag_all_classes,

        // Arena
        test_arena_alloc,
        test_arena_reset,
    ];

    let mut passed: i64 = 0;
    let mut failed: i64 = 0;

    let mut i: i64 = 0;
    while i < 40 {
        let test = tests[i as usize];
        if test() {
            passed += 1;
        } else {
            failed += 1;
            println!("FAILED test {}", i + 1);
        }
        i += 1;
    }

    println!("Zenith tests: {} passed, {} failed", passed, failed);

    if failed > 0 {
        return 1;
    }
    return 0;
}
